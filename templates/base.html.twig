<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Logistica y Tarifas{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <div class="aplicacion">
            {% if app.user %}
                <aside class="barra-lateral">
                    <div>
                        <p class="marca-eyebrow">Panel operativo</p>
                        <h1 class="marca-titulo">Logistica y Tarifas</h1>
                        <p class="marca-texto">Motor de decision logistica en tiempo real.</p>
                    </div>

                    <nav class="navegacion-principal" aria-label="Principal">
                        <a href="{{ path('app_inicio') }}" class="item-menu-principal {{ app.request.attributes.get('_route') == 'app_inicio' ? 'activo' : '' }}">Inicio</a>

                        <div class="item-menu-desplegable {{ app.request.attributes.get('_route') starts with 'app_pedidos_' or app.request.attributes.get('_route') == 'app_simulador_logistico' or app.request.attributes.get('_route') starts with 'app_snapshots_' ? 'activo' : '' }}">
                            <button type="button" class="item-menu-desplegable__trigger">Operacion</button>
                            <div class="submenu-lateral">
                                <a href="{{ path('app_pedidos_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_pedidos_' ? 'activo' : '' }}">Pedidos</a>
                                <a href="{{ path('app_simulador_logistico') }}" class="{{ app.request.attributes.get('_route') == 'app_simulador_logistico' ? 'activo' : '' }}">Simulador</a>
                                <a href="{{ path('app_snapshots_pedido_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_snapshots_' ? 'activo' : '' }}">Snapshots</a>
                            </div>
                        </div>

                        <div class="item-menu-desplegable {{ app.request.attributes.get('_route') starts with 'app_tipos_cliente_' or app.request.attributes.get('_route') starts with 'app_niveles_servicio_' or app.request.attributes.get('_route') starts with 'app_tipos_vehiculo_' ? 'activo' : '' }}">
                            <button type="button" class="item-menu-desplegable__trigger">Catalogos</button>
                            <div class="submenu-lateral">
                                <a href="{{ path('app_tipos_cliente_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_tipos_cliente_' ? 'activo' : '' }}">Tipos de cliente</a>
                                <a href="{{ path('app_niveles_servicio_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_niveles_servicio_' ? 'activo' : '' }}">Servicios</a>
                                <a href="{{ path('app_tipos_vehiculo_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_tipos_vehiculo_' ? 'activo' : '' }}">Vehiculos</a>
                            </div>
                        </div>

                        <div class="item-menu-desplegable {{ app.request.attributes.get('_route') starts with 'app_reglas_disponibilidad_' or app.request.attributes.get('_route') starts with 'app_tarifas_cliente_' or app.request.attributes.get('_route') starts with 'app_tarifas_transportista_' ? 'activo' : '' }}">
                            <button type="button" class="item-menu-desplegable__trigger">Reglas</button>
                            <div class="submenu-lateral">
                                <a href="{{ path('app_reglas_disponibilidad_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_reglas_disponibilidad_' ? 'activo' : '' }}">Disponibilidad</a>
                                <a href="{{ path('app_tarifas_cliente_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_tarifas_cliente_' ? 'activo' : '' }}">Tarifas cliente</a>
                                <a href="{{ path('app_tarifas_transportista_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_tarifas_transportista_' ? 'activo' : '' }}">Tarifas transporte</a>
                            </div>
                        </div>
                    </nav>

                    <div class="panel-usuario">
                        <span class="panel-usuario__nombre">{{ app.user.nombreCompleto }}</span>
                        <span class="panel-usuario__email">{{ app.user.userIdentifier }}</span>
                        <a class="panel-usuario__salir" href="{{ path('app_salir') }}">Cerrar sesion</a>
                    </div>
                </aside>
            {% endif %}

            <main class="contenido-principal{% if not app.user %} contenido-principal--publico{% endif %}">
                {% if app.user %}
                    <header class="cabecera-pagina-global">
                        <div>
                            <p class="cabecera-pagina-global__eyebrow">Backoffice</p>
                            <h2 class="cabecera-pagina-global__titulo">{{ block('title')|replace({' | Logistica y Tarifas': ''}) }}</h2>
                        </div>
                        <div class="cabecera-pagina-global__acciones">
                            <a class="boton-secundario" href="{{ path('app_pedidos_nuevo') }}">Nuevo pedido</a>
                            <a class="boton-principal" href="{{ path('app_simulador_logistico') }}">Abrir simulador</a>
                        </div>
                    </header>
                {% endif %}

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash flash--{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </main>
        </div>
    </body>
</html>
