{% extends 'base.html.twig' %}

{% block title %}{{ titulo }} | Logistica y Tarifas{% endblock %}

{% block body %}
    <section class="tarjeta formulario-admin">
        <div class="cabecera-seccion">
            <div>
                <p class="hero__eyebrow">Operaciones</p>
                <h2>{{ titulo }}</h2>
            </div>
            <a href="{{ path('app_reglas_disponibilidad_index') }}">Volver</a>
        </div>

        {{ form_start(form, {attr: {class: 'formulario-grid'}}) }}
            {{ form_row(form.nivelServicioEntrega) }}
            {{ form_row(form.distanciaMaximaKm) }}
            {{ form_row(form.pesoMaximoGramos) }}
            {{ form_row(form.volumenMaximoCm3) }}
            {{ form_row(form.activa) }}
            {{ form_row(form.guardar, {attr: {class: 'boton-principal'}}) }}
        {{ form_end(form) }}
    </section>
{% endblock %}
