{% extends 'base.html.twig' %}

{% block title %}Pedido {{ pedido.referencia }} | Logistica y Tarifas{% endblock %}

{% block body %}
    <section class="tarjeta">
        <div class="cabecera-seccion">
            <div>
                <p class="hero__eyebrow">Pedido</p>
                <h2>{{ pedido.referencia }}</h2>
                <div class="chips-linea">
                    <span class="chip chip--neutro">{{ pedido.estado.value|title }}</span>
                    <span class="chip chip--suave">{{ pedido.tipoCliente.nombre }}</span>
                    <span class="chip chip--suave">{{ pedido.distanciaKm }} km</span>
                </div>
            </div>
            {% if pedido.estado.value == 'borrador' %}
                <a class="boton-principal" href="{{ path('app_pedidos_editar', {id: pedido.id}) }}">Editar pedido</a>
            {% endif %}
        </div>

        <div class="resumen-grid">
            <article>
                <span>Cliente</span>
                <strong>{{ pedido.nombreCliente }}</strong>
                <p>{{ pedido.telefonoCliente }} · {{ pedido.tipoCliente.nombre }}</p>
            </article>
            <article>
                <span>Distancia</span>
                <strong>{{ pedido.distanciaKm }} km</strong>
                <p>Introducida manualmente para la v1.</p>
            </article>
            <article>
                <span>Estado</span>
                <strong>{{ pedido.estado.value|title }}</strong>
                <p>Peso total: {{ (pedido.pesoTotalGramos / 1000)|number_format(2, ',', '.') }} kg</p>
                <p>Volumen total: {{ pedido.volumenTotalCm3 }} cm3</p>
            </article>
        </div>

        {% if pedido.servicioElegido and pedido.vehiculoElegido %}
            <div class="resumen-grid espacio-superior">
                <article>
                    <span>Servicio confirmado</span>
                    <strong>{{ pedido.servicioElegido.nombre }}</strong>
                    <p>Vehiculo: {{ pedido.vehiculoElegido.nombre }}</p>
                </article>
                <article>
                    <span>Cliente pagaria</span>
                    <strong>{{ pedido.precioClienteCentimos|dinero }}</strong>
                    <p>Importe final visible para el cliente.</p>
                </article>
                <article>
                    <span>Ejecucion</span>
                    <strong>{{ pedido.vehiculoElegido.nombre }}</strong>
                    <p>
                        Coste interno: {{ pedido.costeLogisticoCentimos|dinero }}.
                        El pedido queda bloqueado tras confirmar.
                        {% if pedido.snapshotTarificacion %}
                            <a href="{{ path('app_snapshots_pedido_mostrar', {id: pedido.snapshotTarificacion.id}) }}">Ver snapshot</a>
                        {% endif %}
                    </p>
                </article>
            </div>
        {% endif %}
    </section>

    <section class="tarjeta espacio-superior">
        <div class="cabecera-seccion">
            <div>
                <p class="hero__eyebrow">Decision de entrega</p>
                <h2>Opciones disponibles</h2>
                <p class="seccion-subtexto">Aqui ves primero lo que realmente puede ofrecerse al cliente y despues lo que queda descartado.</p>
            </div>
        </div>

        {% if resultadoEntrega.opciones is empty %}
            <p>No hay opciones ofertables con la configuracion actual del pedido.</p>
        {% else %}
            <div class="simulador-opciones">
                {% for opcion in resultadoEntrega.opciones %}
                    <article class="simulador-opcion">
                        <div class="simulador-opcion__cabecera">
                            <strong>{{ opcion.nivelServicioEntrega.nombre }}</strong>
                            <span>{{ opcion.precioClienteCentimos|dinero }}</span>
                        </div>

                        {% if opcion.vehiculoOptimo %}
                            <p>
                                Vehiculo optimo: <strong>{{ opcion.vehiculoOptimo.tipoVehiculo.nombre }}</strong>
                                · Cliente paga: {{ opcion.precioClienteCentimos|dinero }}
                                · Coste interno: {{ opcion.vehiculoOptimo.costeCentimos|dinero }}
                            </p>
                        {% endif %}

                        <table class="tabla-operativa tabla-operativa--compacta">
                            <thead>
                                <tr>
                                    <th>Vehiculo</th>
                                    <th>Coste</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for vehiculo in opcion.vehiculos %}
                                    <tr>
                                        <td>{{ vehiculo.tipoVehiculo.nombre }}</td>
                                        <td>{{ vehiculo.costeCentimos|dinero }}</td>
                                        <td>
                                            {% if opcion.vehiculoOptimo and vehiculo.tipoVehiculo.id == opcion.vehiculoOptimo.tipoVehiculo.id %}
                                                Recomendado
                                            {% else %}
                                                Compatible
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>

                        {% if pedido.estado.value == 'borrador' and opcion.vehiculoOptimo %}
                            <form method="post" action="{{ path('app_pedidos_confirmar_servicio', {id: pedido.id, servicioId: opcion.nivelServicioEntrega.id}) }}" class="espacio-superior">
                                <input type="hidden" name="_token" value="{{ csrf_token('confirmar_servicio_' ~ pedido.id ~ '_' ~ opcion.nivelServicioEntrega.id) }}">
                                <button type="submit" class="boton-principal">Confirmar este servicio</button>
                            </form>
                        {% endif %}
                    </article>
                {% endfor %}
            </div>
        {% endif %}

        {% if resultadoEntrega.descartes is not empty %}
            <div class="simulador-bloque espacio-superior">
                <h3>Servicios descartados</h3>
                <div class="simulador-descartes">
                    {% for descarte in resultadoEntrega.descartes %}
                        <article class="simulador-descarte">
                            <strong>{{ descarte.nivelServicioEntrega.nombre }}</strong>
                            <p>{{ descarte.motivo }}</p>
                        </article>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </section>

    <section class="tarjeta espacio-superior">
        <div class="cabecera-seccion">
            <div>
                <p class="hero__eyebrow">Carga del pedido</p>
                <h2>Lineas</h2>
                <p class="seccion-subtexto">Estas lineas determinan el peso y el volumen total usados por el motor logistico.</p>
            </div>
        </div>

        <table class="tabla-operativa">
            <thead>
                <tr>
                    <th>Descripcion</th>
                    <th>Cantidad</th>
                    <th>Peso unitario</th>
                    <th>Volumen unitario</th>
                    <th>Subtotal peso</th>
                    <th>Subtotal volumen</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for linea in pedido.lineas %}
                    <tr>
                        <td>{{ linea.descripcion }}</td>
                        <td>{{ linea.cantidad }}</td>
                        <td>{{ linea.pesoUnitarioGramos }} g</td>
                        <td>{{ linea.volumenUnitarioCm3 }} cm3</td>
                        <td>{{ linea.subtotalPesoGramos }} g</td>
                        <td>{{ linea.subtotalVolumenCm3 }} cm3</td>
                        <td class="acciones-linea">
                            {% if pedido.estado.value == 'borrador' %}
                                <a href="{{ path('app_pedidos_lineas_editar', {id: linea.id}) }}">Editar</a>
                                <form method="post" action="{{ path('app_pedidos_lineas_eliminar', {id: linea.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('eliminar_linea_' ~ linea.id) }}">
                                    <button type="submit" class="boton-enlace">Eliminar</button>
                                </form>
                            {% else %}
                                Bloqueado
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">Todavia no hay lineas en este pedido.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    {% if pedido.estado.value == 'borrador' %}
        <section class="tarjeta formulario-admin espacio-superior">
            <div class="cabecera-seccion">
                <div>
                    <p class="hero__eyebrow">Nueva linea</p>
                    <h2>Anadir linea al pedido</h2>
                </div>
            </div>

            {{ form_start(formLinea, {attr: {class: 'formulario-grid'}}) }}
                {{ form_row(formLinea.descripcion) }}
                {{ form_row(formLinea.cantidad) }}
                {{ form_row(formLinea.pesoUnitarioGramos) }}
                {{ form_row(formLinea.volumenUnitarioCm3) }}
                {{ form_row(formLinea.guardar, {attr: {class: 'boton-principal'}}) }}
            {{ form_end(formLinea) }}
        </section>
    {% endif %}
{% endblock %}
